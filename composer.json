{
  "name": "hirasso/rh-admin-utils",
  "description": "A WordPress utility plugin 🥞",
  "license": "GPL-2.0-or-later",
  "autoload": {
    "psr-4": {
      "RH\\AdminUtils\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "RH\\AdminUtils\\": "src",
      "RH\\AdminUtils\\Tests\\": "tests"
    }
  },
  "type": "wordpress-plugin",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org"
    }
  ],
  "require": {
    "php": ">=8.2",
    "composer/installers": "^1.0 || ^2.0",
    "sniccowp/php-scoper-wordpress-excludes": "*",
    "symfony/var-dumper": "^7.1",
    "yahnis-elsts/plugin-update-checker": "^5.6"
  },
  "require-dev": {
    "guzzlehttp/guzzle": "^7.10",
    "laravel/pint": "^1.25",
    "pestphp/pest": "^1.23",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "roots/wordpress": "^6.8",
    "symfony/var-dumper": "^7.1",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "vinkla/extended-acf": "^14.6",
    "wp-cli/wp-cli": "^2.12",
    "wp-phpunit/wp-phpunit": "^6.9",
    "wpackagist-plugin/classic-editor": "^1.6",
    "wpackagist-plugin/sg-security": "^1.5",
    "wpackagist-plugin/simply-static": "^3.5",
    "wpackagist-plugin/wp-super-cache": "^3.0",
    "wpackagist-theme/twentytwentyfive": "^1.4",
    "yoast/wp-test-utils": "^1.2"
  },
  "extra": {
    "installer-paths": {
      "vendor/.wp/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ],
      "vendor/.wp/plugins/{$name}/": [
        "type:wordpress-plugin"
      ],
      "vendor/.wp/themes/{$name}/": [
        "type:wordpress-theme"
      ]
    },
    "wordpress-install-dir": "vendor/.wp/core"
  },
  "scripts": {
    "analyse": "./vendor/bin/phpstan analyse --memory-limit=2G",
    "post-install-cmd": [
      "tools/install-acf-pro vendor/.wp/plugins"
    ],
    "post-update-cmd": [
      "tools/install-acf-pro vendor/.wp/plugins"
    ]
  },
  "scripts-descriptions": {
    "analyse": "Run static analysis"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true,
      "roots/wordpress-core-installer": true
    },
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}
