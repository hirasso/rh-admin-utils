{
  "name": "hirasso/rh-admin-utils",
  "description": "A WordPress utility plugin 🥞",
  "license": "GPL-2.0-or-later",
  "autoload": {
    "psr-4": {
      "RH\\AdminUtils\\": "src"
    }
  },
  "type": "wordpress-plugin",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org"
    }
  ],
  "require": {
    "php": ">=8.2",
    "composer/installers": "^1.0 || ^2.0",
    "sniccowp/php-scoper-wordpress-excludes": "*",
    "symfony/var-dumper": "^7.1",
    "yahnis-elsts/plugin-update-checker": "^5.6"
  },
  "require-dev": {
    "laravel/pint": "^1.21",
    "php-stubs/wordpress-stubs": "^6.9",
    "php-stubs/wp-cli-stubs": "^2.12",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "roots/wordpress": "^6.9",
    "wp-cli/wp-cli": "^2.12",
    "wpackagist-plugin/advanced-custom-fields": "^6.7",
    "wpackagist-plugin/simply-static": "^3.5"
  },
  "extra": {
    "installer-paths": {
      "vendor/.wp/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ],
      "vendor/.wp/plugins/{$name}/": [
        "type:wordpress-plugin"
      ],
      "vendor/.wp/themes/{$name}/": [
        "type:wordpress-theme"
      ]
    },
    "wordpress-install-dir": "vendor/.wp/core"
  },
  "scripts": {
    "analyse": "./vendor/bin/phpstan analyse --memory-limit=2G"
  },
  "scripts-descriptions": {},
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "phpstan/extension-installer": true,
      "roots/wordpress-core-installer": true
    },
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}
