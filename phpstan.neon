parameters:
  level: 3
  paths:
    - rh-admin-utils.php
    - src/
  scanDirectories:
    - vendor/.wp
    - vendor/wp-cli/wp-cli
  ignoreErrors:
    # WordPress constants are defined inside function bodies (e.g. wp_initial_constants())
    # and are therefore invisible to static analysis without a full WP bootstrap.
    - identifier: constant.notFound
